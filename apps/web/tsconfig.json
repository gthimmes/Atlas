{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "types": ["vite/client"],
    "composite": false,
    "noEmit": true
  },
  "include": ["src/**/*", "src/**/*.tsx", "vite.config.ts", "vitest.config.ts"]
}
