root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csproj,sln,slnx,props}]
indent_size = 4
# LF everywhere for cross-platform consistency; git handles checkout translation via .gitattributes.

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
